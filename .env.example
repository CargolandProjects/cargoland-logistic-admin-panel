# Cargoland Admin Panel — environment variables
# Copy this file to `.env.local` and adjust if needed.

# axios baseURL. Defaults to the same-origin proxy (rewritten in next.config.ts
# to BACKEND_ORIGIN) so browser requests avoid CORS. Can also be an absolute URL.
NEXT_PUBLIC_API_URL=/api/cargoland

# Backend origin the proxy forwards to (server-side only, used by next.config.ts).
    BACKEND_ORIGIN=https://dev.cargoland.africa
